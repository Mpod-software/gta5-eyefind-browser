# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.npm/
.pnp.*

# ---------------------------------------------------------------------------
# Build output & packaging artifacts
# ---------------------------------------------------------------------------
dist/
release/
out/
build/Release/
*.exe
*.dmg
*.AppImage
*.blockmap

# electron-builder / electron-rebuild caches
.cache/
.electron-builder-cache/
.eslintcache

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Local environment & secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Editor / OS cruft
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Keep the committed placeholder art. These are generated by
# scripts/generate-assets.js but are tracked so the repo builds straight
# after `git clone` (the `*.exe` rule above must never swallow them — it won't,
# but we whitelist the assets explicitly to make the intent unmistakable).
# ---------------------------------------------------------------------------
!assets/
!assets/icon.ico
!assets/icon.png
!assets/gta-pointer.png
